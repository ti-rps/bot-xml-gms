# Configurações de Ambiente do Bot XML GMS
# Copie este arquivo para .env e configure com seus valores

# Ambiente de execução
# production: Console logs apenas (recomendado para produção)
# development: Console + arquivo de log com rotação (para troubleshooting)
LOG_ENV=production

# Nível de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Configuração de rotação de logs (quando LOG_ENV=development)
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Credenciais GMS
# GMS_USER=seu_usuario_gms
# GMS_PASSWORD=sua_senha_gms

# RabbitMQ - Conexão com fila de mensagens
RABBITMQ_HOST=maestro_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=automation_jobs

# Maestro API - Backend do orquestrador
MAESTRO_API_URL=http://maestro-backend:8000

# API key compartilhada com o maestro (middleware WorkerAPIKey).
# Vazio = bypass: worker não envia o header X-Worker-API-Key e o maestro
# aceita. Pra ligar auth: popular este valor E o MAESTRO_WORKER_API_KEY
# do maestro com a mesma string + restart dos dois lados. Não precisa
# de nova versão do worker.
MAESTRO_WORKER_API_KEY=

# Banco de Dados Maestro - Conexão PostgreSQL
MAESTRO_DB_HOST=postgres
MAESTRO_DB_PORT=5432
MAESTRO_DB_USER=user
MAESTRO_DB_PASSWORD=password
MAESTRO_DB_NAME=maestro_db

# Chrome Driver Path
CHROME_DRIVER_PATH=/usr/local/bin/chromedriver

# Timeouts
PAGE_LOAD_TIMEOUT=30
IMPLICIT_WAIT=10
DOWNLOAD_TIMEOUT=300

# Debug: Defina HEADLESS=false para o navegador aparecer (útil para testar localmente)
# HEADLESS=false
